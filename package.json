{
  "name": "kusto-syntax-highlighting",
  "displayName": "Azure Log Analytics (Kusto) Syntax Highlighting",
  "description": "Support for the Azure Log Analytics (Kusto) language syntax in Visual Studio Code.",
  "version": "2.0.0",
  "publisher": "josin",
  "homepage": "https://github.com/josin/kusto-syntax-highlighting",
  "icon": "images/kusto_logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/josin/kusto-syntax-highlighting"
  },
  "bugs": {
    "url": "https://github.com/josin/kusto-syntax-highlighting/issues"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Languages",
    "Snippets"
  ],
  "keywords": [
    "kusto",
    "kql",
    "azure",
    "azure data explorer",
    "microsoft sentinel",
    "language",
    "highlight",
    "syntax"
  ],
  "license": "Apache-2.0",
  "contributes": {
    "languages": [
      {
        "id": "kusto",
        "aliases": [
          "Kusto",
          "kusto",
          "KQL",
          "kql"
        ],
        "extensions": [
          ".csl",
          ".kusto",
          ".kql"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kusto",
        "scopeName": "source.kusto",
        "path": "./syntaxes/kusto.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "kusto",
        "path": "./snippets/kusto.json"
      }
    ]
  }
}
